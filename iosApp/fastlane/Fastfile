default_platform(:ios)

def bump_build_number!(xcconfig_path:)
  xcconfig = File.read(xcconfig_path)
  current_build = xcconfig[/^CURRENT_PROJECT_VERSION=(\d+)/, 1]&.to_i
  UI.user_error!("CURRENT_PROJECT_VERSION not found in #{xcconfig_path}") unless current_build

  # Simple monotonic increment. The bumped value is committed back to git (see
  # the lane) so it persists across CI runs; without that, every run would read
  # the same committed number and re-upload it, causing "Redundant Binary
  # Upload" errors.
  next_build = current_build + 1

  File.write(
    xcconfig_path,
    xcconfig.sub(/^CURRENT_PROJECT_VERSION=\d+/, "CURRENT_PROJECT_VERSION=#{next_build}")
  )

  UI.success("Build number set to #{next_build}")
  next_build
end

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    app_identifier = "com.arturshamsi.maxlift"
    xcconfig_path = File.expand_path("../Configuration/Config.xcconfig", __dir__)

    # Authenticate with App Store Connect using P8 Auth Key
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true # We will provide the P8 file as a base64 string
    )

    next_build = bump_build_number!(xcconfig_path: xcconfig_path)

    # Persist the bumped build number back to the repo *before* building/uploading.
    # Committing first guarantees a number is never reused even if a later step
    # fails (gaps in build numbers are harmless to TestFlight; collisions are not).
    git_commit(
      path: xcconfig_path,
      message: "ci: bump iOS build number to #{next_build} [skip ci]"
    )
    push_to_git_remote

    # Kotlin framework is built by the Xcode "Compile Kotlin Framework" run script
    # (embedAndSignAppleFrameworkForXcode), which outputs to the path in Config.xcconfig.

    # App Store archives require Apple Distribution + manual signing in CI
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "iosApp.xcodeproj",
      team_id: ENV["TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      profile_name: ENV["PROVISIONING_PROFILE_NAME"],
      bundle_identifier: app_identifier
    )

    # Build and upload
    build_app(
      scheme: "iosApp",
      project: "iosApp.xcodeproj",
      include_bitcode: false,
      export_method: "app-store",
      clean: true,
      export_options: {
        provisioningProfiles: {
          app_identifier => ENV["PROVISIONING_PROFILE_NAME"]
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
