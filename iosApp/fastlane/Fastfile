default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    # Authenticate with App Store Connect using P8 Auth Key
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true # We will provide the P8 file as a base64 string
    )

    # Kotlin framework is built by the Xcode "Compile Kotlin Framework" run script
    # (embedAndSignAppleFrameworkForXcode), which outputs to the path in Config.xcconfig.

    # App Store archives require Apple Distribution + manual signing in CI
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "iosApp.xcodeproj",
      team_id: ENV["TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      profile_name: ENV["PROVISIONING_PROFILE_NAME"],
      bundle_identifier: "com.arturshamsi.maxlift"
    )

    # Build and upload
    build_app(
      scheme: "iosApp",
      project: "iosApp.xcodeproj",
      include_bitcode: false,
      export_method: "app-store",
      clean: true,
      export_options: {
        provisioningProfiles: {
          "com.arturshamsi.maxlift" => ENV["PROVISIONING_PROFILE_NAME"]
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
